{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ruff: lint",
      "type": "shell",
      "command": "uv run ruff check .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "ruff: lint (fix)",
      "type": "shell",
      "command": "uv run ruff check --fix .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "ruff: format",
      "type": "shell",
      "command": "uv run ruff format .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "ty: typecheck",
      "type": "shell",
      "command": "uv run ty check",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "test: run all",
      "type": "shell",
      "command": "uv run pytest",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "test: run current file",
      "type": "shell",
      "command": "uv run pytest ${file} -v",
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "test: coverage",
      "type": "shell",
      "command": "uv run pytest --cov=src --cov-report=term-missing",
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "check: all",
      "dependsOrder": "sequence",
      "dependsOn": ["ruff: format", "ruff: lint", "ty: typecheck", "test: run all"],
      "problemMatcher": []
    }
  ]
}
